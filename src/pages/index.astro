---
// 1. Astroship의 기본 레이아웃과 컴포넌트를 불러옵니다.
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import officeImg from "../images/centralmainimg.jpg";

// 신규 React 컴포넌트
import Hero from "../components/Hero.jsx";
import QuickMenu from "../components/QuickMenu.jsx";
import InquiryForm from "../components/InquiryForm.jsx";
import ReviewCard from "../components/ReviewCard.jsx";
import VisitReservationButton from "../components/VisitReservationButton.jsx";

const siteName = "센트럴공인중개사 사무소";
const ceoName = "박은미";
const contact = "031-721-0082";
const address = "경기도 성남시 중원구 여수울로15번길 4-4, 107호(여수동)";
const regNo = "41133-2020-00049";
---
<!-- 1. goToNaverLand 함수: is:inline으로 전역 등록 -->
<script is:inline>
  function goToNaverLand() {
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    const targetUrl = isMobile
      ? "https://fin.land.naver.com/realtor/tpsxmfjfrhddls?complexNumber=102283&articleTradeTypes=A1"
      : "https://new.land.naver.com?realtorId=tpsxmfjfrhddls";
    if (targetUrl) window.location.href = targetUrl;
  }
</script>
<!--
  2. 네이버 지도 API 로드
     - ncpClientId: 발급받은 Client ID
     - submodules=geocoder: 주소→좌표 변환 모듈 (필수!)
-->
<script
  is:inline
  type="text/javascript"
  src="https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=7zkmud7ekw"
></script>
<!--
  3. 지도 초기화 스크립트
     - define:vars로 Astro 서버 변수 address를 클라이언트에 주입
     - is:inline 사용 시 define:vars가 안 되므로 일반 <script>로 작성
-->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    function waitForNaver(callback) {
      if (typeof naver !== "undefined" && naver.maps) {
        callback();
      } else {
        setTimeout(function () { waitForNaver(callback); }, 100);
      }
    }

    waitForNaver(function () {
      // 좌표 하드코딩 (Geocoder 불필요 → CORS 문제 없음)
      var coord = new naver.maps.LatLng(37.418920, 127.130942);

      var map = new naver.maps.Map("map", {
        center: coord,
        zoom: 17,
        zoomControl: true,
        zoomControlOptions: {
          position: naver.maps.Position.TOP_RIGHT,
        },
      });

      new naver.maps.Marker({
        position: coord,
        map: map,
        animation: naver.maps.Animation.DROP,
      });

      // 길찾기 버튼 활성화
      var btn = document.getElementById("map-directions-btn");
      if (btn) {
        btn.style.display = "inline-flex";
        btn.addEventListener("click", function () {
          window.open(
            "https://map.naver.com/p/directions/-/127.1426,37.4436,%EC%84%BC%ED%8A%B8%EB%9F%B4%EA%B3%B5%EC%9D%B8%EC%A4%91%EA%B0%9C%EC%82%AC,,/car?c=15,0,0,0,dh",
            "_blank"
          );
        });
      }
    });
  });
</script>
<Layout title="여수동 센트럴공인중개사 사무소">
  <Container>
	<header class="flex flex-col lg:flex-row justify-between items-center my-5 gap-3">
    <div class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg flex items-center">
        <span class="font-bold text-slate-800 text-2xl">센트럴공인중개사</span>
        </a>
        <div class="lg:hidden">
            <VisitReservationButton client:load />
        </div>
    </div>

    <div class="hidden lg:flex items-center gap-6">
        <!-- 비즈니스 정보 배치 -->
        <div class="flex flex-col items-end">
        <span class="text-[10px] text-slate-400 uppercase tracking-widest">Consulting</span>
        <a href="tel:031-721-0082" class="text-xl font-bold text-slate-800 hover:text-violet-500 transition">
            031-721-0082
        </a>
        </div>
        <!-- 강조된 버튼 -->
        <VisitReservationButton client:load />
    </div>
    </header>

    <main class="mt-16">
      <!-- 히어로: 새 디자인 (그라디언트 + 급매물/전화 CTA + 네이버 링크 내장) -->
      <Hero contact={contact} client:load />

      <!-- 퀵메뉴: 단지비교 · 학군정보 · 개발호재 · 급매물 -->
      <QuickMenu client:load />

      <!-- 희망 조건 매물 신청 폼 -->
      <div class="px-1 pb-4">
        <InquiryForm client:load />
      </div>

		<!-- 사장님 프로필 섹션 -->
		<section class="max-w-6xl mx-auto px-6 py-20 border-b border-slate-200">
			<div class="flex flex-col md:flex-row items-start gap-12">
				<div class="w-full md:w-[500px] h-64 md:h-72 rounded-2xl overflow-hidden shadow-lg shrink-0">
					<img 
						src={officeImg.src} 
						alt="센트럴공인중개사 사무소 외관" 
						class="w-full h-full object-cover object-center"
					/>
				</div>
				<div>
					<h3 class="text-2xl font-bold mb-4">대표 공인중개사    <span class="text-violet-500 whitespace-nowrap">{ceoName}</span></h3>
					<p class="text-lg text-slate-600 mb-6 leading-relaxed">
						성남 여수동 지역에서 오랜 기간 쌓아온 전문 지식과 정직함을 바탕으로 고객님의 소중한 자산을 관리해 드립니다. 
						단순한 매칭을 넘어, 고객님의 라이프스타일과 투자 목적에 최적화된 매물을 제안하겠습니다.
					</p>
					<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-slate-700 font-medium">
						<li class="flex items-center gap-2">✅ 공인중개사 자격 보유</li>
						<li class="flex items-center gap-2">✅ 여수동 지역 매물 분석 전문가</li>
						<li class="flex items-center gap-2">✅ 상가 임대차 전문 컨설팅</li>
						<li class="flex items-center gap-2">✅ 신속하고 정확한 법률 검토</li>
					</ul>

					<!-- 계약 성공 후기 미리보기 -->
					<div class="mt-6">
						<ReviewCard client:load />
					</div>
				</div>
			</div>
		</section>

		<!-- 주요 서비스 섹션 -->
		<section class="bg-white py-20 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h3 class="text-3xl font-bold mb-4">전문 중개 영역</h3>
					<p class="text-slate-500">센트럴은 전문성을 바탕으로 다양한 부동산 서비스를 제공합니다.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-violet-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🏢</div>
						<h4 class="text-xl font-bold mb-2">아파트/오피스텔</h4>
						<p class="text-slate-600">실거주 목적의 최적 단지 추천 및 철저한 권리 분석을 통한 안전한 계약 진행</p>
					</div>
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-violet-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🛍️</div>
						<h4 class="text-xl font-bold mb-2">상가/사무실</h4>
						<p class="text-slate-600">유동인구 분석과 수익률 시뮬레이션을 통한 성공적인 창업 및 투자 가이드</p>
					</div>
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-violet-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🏗️</div>
						<h4 class="text-xl font-bold mb-2">토지/빌딩</h4>
						<p class="text-slate-600">용도 분석과 향후 가치 상승을 고려한 토지 매입 및 빌딩 자산 관리 전문 솔루션</p>
					</div>
				</div>
			</div>
		</section>

		<!-- 위치 안내 섹션 (네이버 지도 이동 포함) -->
		<section id="contact" class="max-w-6xl mx-auto px-6 py-20">
			<div class="flex justify-between items-center mb-10">
				<h3 class="text-3xl font-bold">오시는 길</h3>
				<a href="https://naver.me/G0p8taK9" target="_blank" class="text-violet-500 font-bold hover:underline">네이버 지도로 보기 &rarr;</a>
			</div>
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
				<div id="map" class="bg-slate-200 h-96 rounded-3xl overflow-hidden relative shadow-inner">
					<div class="w-full h-full flex items-center justify-center bg-slate-100 text-slate-400">
						지도를 불러오는 중...
					</div>
				</div>
				<div class="flex flex-col justify-center">
					<div class="mb-8">
						<p class="text-sm font-bold text-violet-500 mb-2 uppercase">Address</p>
						<p class="text-xl text-slate-800">{address}</p>
					</div>
					<div class="mb-8">
						<p class="text-sm font-bold text-violet-500 mb-2 uppercase">Call Us</p>
						<p class="text-3xl font-black text-slate-900">{contact}</p>
						<p class="text-slate-500 mt-2">상담 시간: 09:30 - 21:00</p>
						<p class="text-slate-500 mt-2">영업 시간: (월~토) 09:30 - 20:00</p>
					</div>					
					<button onclick={`location.href='tel:${contact}'`} class="w-full bg-violet-400 text-white py-4 rounded-xl font-bold hover:bg-violet-500 transition shadow-lg">
						지금 바로 전화 상담하기
					</button>
				</div>
			</div>
		</section>
    </main>
	<footer class="bg-violet-50 text-slate-600 py-16 px-6 border-t border-violet-100">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
				<div>
					<h4 class="text-slate-800 text-xl font-bold mb-6 tracking-tight">{siteName}</h4>
					<p class="text-sm leading-relaxed">
						성남시 여수동 일대의 모든 부동산 거래는<br/> 
						정직과 실력을 겸비한 센트럴공인중개사와 상의하세요.<br/>
						고객님의 소중한 자산을 내 가족의 일처럼 소중히 다루겠습니다.
					</p>
				</div>
				<div class="text-sm">
					<p class="mb-2"><span class="text-slate-800 font-medium">대표자:</span> {ceoName}</p>
					<p class="mb-2"><span class="text-slate-800 font-medium">등록번호:</span> {regNo}</p>
					<p class="mb-2"><span class="text-slate-800 font-medium">대표번호:</span> {contact}</p>
					<p class="mb-2"><span class="text-slate-800 font-medium">사무실 주소:</span> {address}</p>
					<p class="mb-2"><span class="text-slate-800 font-medium">경제 정보 채널:</span> <a href="https://t.me/centralpem" target="_blank" class="text-violet-500 hover:text-violet-600 transition-colors">텔레그램 바로가기</a></p>
					<p><span class="text-slate-800 font-medium">경제 정보 블로그:</span> <a href="https://www.ezbiztok.com/" target="_blank" class="text-violet-500 hover:text-violet-600 transition-colors">블로그 바로가기</a></p>
				</div>
			</div>
			<div class="pt-8 border-t border-violet-200 flex flex-col md:flex-row justify-between items-center text-xs text-slate-500">
				<p>© 2026 {siteName}. All rights reserved.</p>
				<div class="flex gap-4 mt-4 md:mt-0 uppercase font-semibold">
					<a href="/privacy" class="hover:text-violet-500 transition">Privacy Policy</a>
					<a href="/terms" class="hover:text-violet-500 transition">Terms of Service</a>
				</div>
			</div>
		</div>
	</footer>
  </Container>
</Layout>