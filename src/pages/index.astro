---
// 1. Astroship의 기본 레이아웃과 컴포넌트를 불러옵니다.
import Layout from "../layouts/Layout.astro";
//import Hero from "../components/hero.astro";
//import Footer from "../components/footer.astro";
import Container from "../components/container.astro";
import officeImg from "../images/centralmainimg.jpg";

const siteName = "센트럴공인중개사 사무소";
const ceoName = "박은미";
const contact = "031-721-0082";
const address = "경기도 성남시 중원구 여수울로15번길 4-4, 107호(여수동)";
const regNo = "41133-2020-00049";
---
<!-- 1. goToNaverLand 함수: is:inline으로 전역 등록 -->
<script is:inline>
  function goToNaverLand() {
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    const targetUrl = isMobile
      ? "https://fin.land.naver.com/realtor/tpsxmfjfrhddls?complexNumber=102283&articleTradeTypes=A1"
      : "https://new.land.naver.com?realtorId=tpsxmfjfrhddls";
    if (targetUrl) window.location.href = targetUrl;
  }
</script> 
<!--
  2. 네이버 지도 API 로드
     - ncpClientId: 발급받은 Client ID
     - submodules=geocoder: 주소→좌표 변환 모듈 (필수!)
-->
<script
  is:inline
  type="text/javascript"
  src="https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=7zkmud7ekw"
></script> 
<!--
  3. 지도 초기화 스크립트
     - define:vars로 Astro 서버 변수 address를 클라이언트에 주입
     - is:inline 사용 시 define:vars가 안 되므로 일반 <script>로 작성
-->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    function waitForNaver(callback) {
      if (typeof naver !== "undefined" && naver.maps) {
        callback();
      } else {
        setTimeout(function () { waitForNaver(callback); }, 100);
      }
    }

    waitForNaver(function () {
      // 좌표 하드코딩 (Geocoder 불필요 → CORS 문제 없음)
      var coord = new naver.maps.LatLng(37.418920, 127.130942);

      var map = new naver.maps.Map("map", {
        center: coord,
        zoom: 17,
        zoomControl: true,
        zoomControlOptions: {
          position: naver.maps.Position.TOP_RIGHT,
        },
      });

      new naver.maps.Marker({
        position: coord,
        map: map,
        animation: naver.maps.Animation.DROP,
      });

      // 길찾기 버튼 활성화
      var btn = document.getElementById("map-directions-btn");
      if (btn) {
        btn.style.display = "inline-flex";
        btn.addEventListener("click", function () {
          window.open(
            "https://map.naver.com/p/directions/-/127.1426,37.4436,%EC%84%BC%ED%8A%B8%EB%9F%B4%EA%B3%B5%EC%9D%B8%EC%A4%91%EA%B0%9C%EC%82%AC,,/car?c=15,0,0,0,dh",
            "_blank"
          );
        });
      }
    });
  });
</script>
<Layout title="여수동 센트럴공인중개사 사무소">
  <Container>
	<header class="flex flex-col lg:flex-row justify-between items-center my-5">
		<div class="flex w-full lg:w-auto items-center justify-between">
			<a href="/" class="text-lg flex items-center">
			<span class="font-bold text-slate-800 text-2xl">센트럴공인중개사 사무소</span>
			</a>
		</div>

		<div class="hidden lg:flex items-center gap-6">
			<!-- 비즈니스 정보 배치 -->
			<div class="flex flex-col items-end">
			<span class="text-[10px] text-slate-400 uppercase tracking-widest">Consulting</span>
			<a href="tel:031-721-0082" class="text-xl font-bold text-slate-800 hover:text-blue-600 transition">
				031-721-0082
			</a>
			</div>
			<!-- 강조된 버튼 -->
			<a href="#contact" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-slate-800 transition">
			방문 예약하기
			</a>
		</div>
		</header>
<!--		
    <head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{siteName} - 성남 여수동 부동산 전문가</title>
		
		<-- [핵심] 모든 설정을 무시하고 Tailwind 디자인을 강제로 불러오는 링크입니다 >
		<link href="https://cdn.jsdelivr.net" rel="stylesheet">
		
		<-- 폰트 설정 (선택사항) >
		<link href="https://fonts.googleapis.com" rel="stylesheet">
		<style>
			body { font-family: 'Noto Sans KR', sans-serif; }
		</style>
	</head>
-->
    <main class="mt-16">
      <!-- 히어로: 신뢰감 있는 첫인상 -->
		<section class="relative bg-slate-900 text-white py-24 px-6 overflow-hidden">
			<div class="absolute inset-0 opacity-30 bg-[url('https://images.unsplash.com')] bg-cover bg-center"></div>
			<div class="relative z-10 max-w-4xl mx-auto text-center">
				<span class="inline-block bg-blue-600 text-xs font-bold px-3 py-1 rounded-full mb-6 uppercase tracking-wider">성남 여수동 전문</span>
				<h2 class="text-2xl md:text-5xl font-extrabold mb-6 leading-tight">정직한 중개, 확실한 분석<br/>센트럴이 함께합니다</h2>
				<p class="text-lg md:text-xl text-slate-300 mb-10 font-light">여수동 아파트·상가·오피스텔 매물 보유 및 맞춤형 컨설팅</p>
				<div class="flex flex-col sm:flex-row justify-center gap-4">
<!--					<a href="https://new.land.naver.com?realtorId=tpsxmfjfrhddls" target="_blank" class="bg-[#03C75A] text-white px-8 py-4 rounded-xl font-bold text-lg hover:shadow-lg transition">N 네이버 실시간 매물보기</a> -->
					<!-- href는 빈 링크(#)나 javascript:void(0)로 두고, onclick에 함수를 연결합니다 -->
					<a 
					href="javascript:void(0);" 
					onclick="goToNaverLand()" 
					class="inline-block bg-[#03C75A] text-white px-8 py-4 rounded-xl font-bold text-lg hover:shadow-lg transition cursor-pointer"
					>
					<span class="mr-2">N</span> 네이버 실시간 매물보기
					</a>
					<a href={`tel:${contact}`} class="bg-white text-slate-900 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-100 transition">전화 상담하기</a>
				</div>
			</div>
		</section>

		<!-- 사장님 프로필 섹션 -->
		<section class="max-w-6xl mx-auto px-6 py-20 border-b border-slate-200">
			<!-- 수정: items-start로 변경해서 이미지 크기에 맞게 정렬 -->
			<div class="flex flex-col md:flex-row items-start gap-12">
				<!-- 수정: 와이드 비율로 변경, 섹션 전체 레이아웃도 조정 -->
				<div class="w-full md:w-[500px] h-64 md:h-72 rounded-2xl overflow-hidden shadow-lg shrink-0">
					<img 
						src={officeImg.src} 
						alt="센트럴공인중개사 사무소 외관" 
						class="w-full h-full object-cover object-center"
					/>
				</div>
				<div>
					<h3 class="text-2xl font-bold mb-4">대표 공인중개사    <span class="text-blue-600 whitespace-nowrap">{ceoName}</span></h3>
					<p class="text-lg text-slate-600 mb-6 leading-relaxed">
						성남 여수동 지역에서 오랜 기간 쌓아온 전문 지식과 정직함을 바탕으로 고객님의 소중한 자산을 관리해 드립니다. 
						단순한 매칭을 넘어, 고객님의 라이프스타일과 투자 목적에 최적화된 매물을 제안하겠습니다.
					</p>
					<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-slate-700 font-medium">
						<li class="flex items-center gap-2">✅ 공인중개사 자격 보유</li>
						<li class="flex items-center gap-2">✅ 여수동 지역 매물 분석 전문가</li>
						<li class="flex items-center gap-2">✅ 상가 임대차 전문 컨설팅</li>
						<li class="flex items-center gap-2">✅ 신속하고 정확한 법률 검토</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- 주요 서비스 섹션 -->
		<section class="bg-white py-20 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="text-center mb-16">
					<h3 class="text-3xl font-bold mb-4">전문 중개 영역</h3>
					<p class="text-slate-500">센트럴은 전문성을 바탕으로 다양한 부동산 서비스를 제공합니다.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-blue-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🏢</div>
						<h4 class="text-xl font-bold mb-2">아파트/오피스텔</h4>
						<p class="text-slate-600">실거주 목적의 최적 단지 추천 및 철저한 권리 분석을 통한 안전한 계약 진행</p>
					</div>
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-blue-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🛍️</div>
						<h4 class="text-xl font-bold mb-2">상가/사무실</h4>
						<p class="text-slate-600">유동인구 분석과 수익률 시뮬레이션을 통한 성공적인 창업 및 투자 가이드</p>
					</div>
					<div class="p-8 bg-slate-50 rounded-2xl hover:bg-blue-50 transition group">
						<div class="text-4xl mb-4 group-hover:scale-110 transition">🏗️</div>
						<h4 class="text-xl font-bold mb-2">토지/빌딩</h4>
						<p class="text-slate-600">용도 분석과 향후 가치 상승을 고려한 토지 매입 및 빌딩 자산 관리 전문 솔루션</p>
					</div>
				</div>
			</div>
		</section>

		<!-- 위치 안내 섹션 (네이버 지도 이동 포함) -->
		<section id="contact" class="max-w-6xl mx-auto px-6 py-20">
			<div class="flex justify-between items-center mb-10">
				<h3 class="text-3xl font-bold">오시는 길</h3>
				<a href="https://naver.me/G0p8taK9" target="_blank" class="text-blue-600 font-bold hover:underline">네이버 지도로 보기 &rarr;</a>
			</div>
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
				<!-- 수정된 지도 영역 -->
				<div id="map" class="bg-slate-200 h-96 rounded-3xl overflow-hidden relative shadow-inner">
					<!-- API 로딩 전 노출될 배경 -->
					<div class="w-full h-full flex items-center justify-center bg-slate-100 text-slate-400">
						지도를 불러오는 중...
					</div>
				</div>
				<div class="flex flex-col justify-center">
					<div class="mb-8">
						<p class="text-sm font-bold text-blue-600 mb-2 uppercase">Address</p>
						<p class="text-xl text-slate-800">{address}</p>
					</div>
					<div class="mb-8">
						<p class="text-sm font-bold text-blue-600 mb-2 uppercase">Call Us</p>
						<p class="text-3xl font-black text-slate-900">{contact}</p>
						<p class="text-slate-500 mt-2">상담 시간: 09:30 - 21:00</p>
						<p class="text-slate-500 mt-2">영업 시간: (월~토) 09:30 - 20:00</p>
					</div>					
					<button onclick={`location.href='tel:${contact}'`} class="w-full bg-slate-900 text-white py-4 rounded-xl font-bold hover:bg-slate-800 transition shadow-lg">
						지금 바로 전화 상담하기
					</button>
				</div>
			</div>
		</section>
    </main>
	<footer class="bg-slate-900 text-slate-400 py-16 px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
				<div>
					<h4 class="text-white text-xl font-bold mb-6 tracking-tight">{siteName}</h4>
					<p class="text-sm leading-relaxed">
						성남시 여수동 일대의 모든 부동산 거래는<br/> 
						정직과 실력을 겸비한 센트럴공인중개사와 상의하세요.<br/>
						고객님의 소중한 자산을 내 가족의 일처럼 소중히 다루겠습니다.
					</p>
				</div>
				<div class="text-sm">
					<p class="mb-2"><span class="text-slate-300">대표자:</span> {ceoName}</p>
					<p class="mb-2"><span class="text-slate-300">등록번호:</span> {regNo}</p>
					<p class="mb-2"><span class="text-slate-300">대표번호:</span> {contact}</p>
					<p  class="mb-2"><span class="text-slate-300">사무실 주소:</span> {address}</p>
					<p><span class="text-slate-300">경제 정보 채널:</span> <a href="https://t.me/centralpem" class="hover:text-white transition-colors">텔레그램 바로가기</a></p>
				</div>
			</div>
			<div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center text-xs">
				<p>© 2026 {siteName}. All rights reserved.</p>
				<div class="flex gap-4 mt-4 md:mt-0 uppercase font-semibold">
					<a href="/privacy" class="hover:text-white transition">Privacy Policy</a>
					<a href="/terms" class="hover:text-white transition">Terms of Service</a>
				</div>
			</div>
		</div>
	</footer>
  </Container>
</Layout>
