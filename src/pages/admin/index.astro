---
import "../../styles/global.css";
import AdminApp from "../../components/AdminApp.jsx";
import ChangePasswordButton from "../../components/ChangePasswordButton.jsx";

export const prerender = false;
const username = Astro.locals.admin?.username ?? "관리자";
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>관리자 페이지 | 센트럴공인중개사</title>
</head>
<body class="min-h-screen bg-gradient-to-b from-slate-50 to-violet-50/40">
  <header class="bg-white/90 backdrop-blur border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-400 to-violet-500 text-white flex items-center justify-center font-bold text-sm shadow-sm">
          센
        </div>
        <div>
          <h1 class="text-sm font-semibold text-slate-800 leading-tight">센트럴공인중개사 관리자 화면</h1>
          <p class="text-[11px] text-slate-400 leading-tight">여수동 센트럴공인중개사 사무소</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs text-slate-500 bg-slate-100 px-3 py-1.5 rounded-full">{username}님</span>
        <ChangePasswordButton client:load />
        <button
          id="logout-btn"
          class="text-xs text-slate-500 border border-slate-200 rounded-full px-3 py-1.5 hover:bg-slate-100 transition"
        >
          로그아웃
        </button>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto p-6">
    <AdminApp client:load />
  </main>

  <script is:inline>
    document.getElementById("logout-btn").addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = "/admin/login";
    });
  </script>
</body>
</html>